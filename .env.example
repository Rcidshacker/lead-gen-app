# LeadForge — Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=LeadForge
APP_ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# =============================================================================
# DATABASE — PostgreSQL + pgvector
# =============================================================================
DATABASE_URL=postgresql+asyncpg://leadforge:leadforge@localhost:5432/leadforge
DATABASE_SYNC_URL=postgresql://leadforge:leadforge@localhost:5432/leadforge

# =============================================================================
# REDIS — Message Broker & Cache
# =============================================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# LLM API KEYS (at least one required for ScrapeGraphAI)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ScrapeGraphAI Model Configuration
SGAI_MODEL=gpt-4o-mini
SGAI_TEMPERATURE=0.1
SGAI_MAX_TOKENS=4096

# =============================================================================
# AUTHENTICATION — JWT
# =============================================================================
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# SCRAPER CONFIGURATION
# =============================================================================
SCRAPER_DEFAULT_DELAY=2
SCRAPER_MAX_CONCURRENT=3
SCRAPER_TIMEOUT=30
SCRAPER_ROTATE_USER_AGENT=true

# =============================================================================
# WEBHOOK CONFIGURATION (Optional)
# =============================================================================
# WEBHOOK_URL=https://your-webhook-endpoint.com/api/leads
# WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# EMAIL NOTIFICATIONS (Optional)
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# POSTGRES (Docker)
# =============================================================================
POSTGRES_USER=leadforge
POSTGRES_PASSWORD=leadforge
POSTGRES_DB=leadforge
